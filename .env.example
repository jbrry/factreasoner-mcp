# IBM Watsonx credentials (required for default model)
WATSONX_API_KEY=
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=

# Google Search retrieval via Serper API (required if using retriever_type="google")
SERPER_API_KEY=

# Path to compiled Merlin binary (required)
# Build from: https://github.com/radum2275/merlin
MERLIN_PATH=/path/to/merlin

# Optional overrides
# FACTREASONER_MODEL_ID=watsonx/ibm/granite-3-3-8b-instruct
# MAX_CONCURRENT_LLM_REQUESTS=4
